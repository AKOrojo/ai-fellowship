{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Fellowships data file",
  "type": "object",
  "additionalProperties": false,
  "required": ["fellowships"],
  "properties": {
    "fellowships": {
      "type": "array",
      "maxItems": 2000,
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "organization", "category", "url", "description", "location", "cycles", "last_verified"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$" },
        "name": { "type": "string", "minLength": 1, "maxLength": 120 },
        "organization": { "type": "string", "minLength": 1, "maxLength": 120 },
        "category": { "type": "string", "enum": ["industry-residency", "research-safety", "academic-phd", "policy-grants"] },
        "url": { "type": "string", "maxLength": 500 },
        "description": { "type": "string", "minLength": 1, "maxLength": 500 },
        "location": { "type": "string", "minLength": 1, "maxLength": 80 },
        "eligibility": { "type": "string", "maxLength": 200 },
        "funding": { "type": "string", "maxLength": 120 },
        "duration": { "type": "string", "maxLength": 80 },
        "tags": {
          "type": "array",
          "maxItems": 8,
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,29}$" }
        },
        "source": { "type": "string", "maxLength": 500 },
        "last_verified": { "type": "string", "maxLength": 10 },
        "cycles": {
          "type": "array",
          "minItems": 1,
          "maxItems": 24,
          "items": { "$ref": "#/$defs/cycle" }
        }
      }
    },
    "cycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cycle", "deadline"],
      "properties": {
        "cycle": { "type": "string", "minLength": 1, "maxLength": 60 },
        "opens": { "type": "string", "maxLength": 10 },
        "deadline": { "type": "string", "maxLength": 10 }
      }
    }
  }
}
